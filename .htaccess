Options -Indexes

# Enable mod_rewrite
RewriteEngine On

# Force HTTPS (uncomment when SSL is active)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── 301 Redirects: old .html URLs → new clean slugs ───────────────────
RewriteRule ^index\.html$ / [L,R=301]
RewriteRule ^putna-pomosht-sofia\.html$ /putna-pomosht-sofia/ [L,R=301]
RewriteRule ^putna-pomosht-ceni\.html$ /putna-pomosht-ceni/ [L,R=301]
RewriteRule ^transportni-uslugi\.html$ /transportni-uslugi/ [L,R=301]
RewriteRule ^contacts\.html$ /kontakti/ [L,R=301]

# ─── Old canonical redirects ────────────────────────────────────────────
RewriteRule ^contacts/?$ /kontakti/ [L,R=301]
RewriteRule ^uslugi/?$ /transportni-uslugi/ [L,R=301]

# ─── Clean URL routing: serve index.html from subdirectories ───────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-z0-9-]+)/?$ /$1/index.html [L]

# Custom 404
ErrorDocument 404 /404.html
